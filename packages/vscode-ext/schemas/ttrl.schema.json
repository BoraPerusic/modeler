{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TTR Layout",
  "description": "Layout sidecar for TTR model files. Managed by the LSP — do not edit by hand.",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Layout format version. Current is 1."
    },
    "viewports": {
      "type": "object",
      "description": "Per-schema viewport state.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "zoom": { "type": "number", "default": 1.0 },
          "panX": { "type": "number", "default": 0 },
          "panY": { "type": "number", "default": 0 },
          "displayMode": {
            "type": "string",
            "enum": ["just-names", "with-types", "with-constraints", "with-indices", "full"],
            "default": "just-names"
          }
        },
        "additionalProperties": false
      }
    },
    "nodes": {
      "type": "object",
      "description": "Node positions keyed by qname.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        },
        "required": ["x", "y"],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "object",
      "description": "Edge layout hints keyed by qname.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "bendPoints": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}