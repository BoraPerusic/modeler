{
  "name": "TTR",
  "fileTypes": [
    "ttr"
  ],
  "scopeName": "source.ttr",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ttr",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ttr",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.ttr",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.ttr",
          "begin": "\"",
          "end": "\"(?=[^\\\\])",
          "patterns": [
            {
              "name": "constant.character.escape.ttr",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ttr",
          "match": "-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "include": "#keyword_control_def_ttr"
        },
        {
          "include": "#keyword_other_schema_ttr"
        },
        {
          "include": "#keyword_other_kind_ttr"
        },
        {
          "include": "#keyword_other_property_ttr"
        }
      ]
    },
    "keyword_control_def_ttr": {
      "patterns": [
        {
          "scope": "keyword.control.def.ttr",
          "match": "\\b(def|schema|namespace)\\b"
        }
      ]
    },
    "keyword_other_schema_ttr": {
      "patterns": [
        {
          "scope": "keyword.other.schema.ttr",
          "match": "\\b(db|er|map|cnc|query)\\b"
        }
      ]
    },
    "keyword_other_kind_ttr": {
      "patterns": [
        {
          "scope": "keyword.other.kind.ttr",
          "match": "\\b(model|table|view|column|index|constraint|fk|procedure|entity|attribute|relation|er2db_entity|er2db_attribute|er2db_relation|role|er2cnc_role)\\b"
        }
      ]
    },
    "keyword_other_property_ttr": {
      "patterns": [
        {
          "scope": "keyword.other.property.ttr",
          "match": "\\b(description|tags|version|primaryKey|columns|indices|constraints|attributes|parameters|resultColumns|definitionSql|type|optional|isKey|searchable|indexed|labelPlural|nameAttribute|codeAttribute|aliases|cardinality|join|target|whereFilter|language|sourceText|length|precision|label|name|direction|displayLabel|valueLabels|roles|search|keywords|patterns|descriptions|examples|from|to)\\b"
        }
      ]
    },
    "support_type_primitive_ttr": {
      "patterns": [
        {
          "scope": "support.type.primitive.ttr",
          "match": "\\b(text|int|float|bool|datetime|string|boolean|number|integer|double|object|list|char|varchar|decimal|date|timestamp)\\b"
        }
      ]
    },
    "constant_language_ttr": {
      "patterns": [
        {
          "scope": "constant.language.ttr",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "constant_language_indextype_ttr": {
      "patterns": [
        {
          "scope": "constant.language.indextype.ttr",
          "match": "\\b(primary|secondary|ordered|btree|fulltext)\\b"
        }
      ]
    },
    "constant_language_constrainttype_ttr": {
      "patterns": [
        {
          "scope": "constant.language.constrainttype.ttr",
          "match": "\\b(unique|notNull)\\b"
        }
      ]
    },
    "constant_language_querylang_ttr": {
      "patterns": [
        {
          "scope": "constant.language.querylang.ttr",
          "match": "\\b(SQL|TRANSFORMATION_DSL|DATAFRAME_DSL|REL_NODE)\\b"
        }
      ]
    },
    "punctuation_separator_ttr": {
      "patterns": [
        {
          "scope": "punctuation.separator.ttr",
          "match": "\\b(=|:|,|\\.)\\b"
        }
      ]
    },
    "punctuation_section_braces_ttr": {
      "patterns": [
        {
          "scope": "punctuation.section.braces.ttr",
          "match": "\\b(\\{|\\})\\b"
        }
      ]
    },
    "punctuation_section_brackets_ttr": {
      "patterns": [
        {
          "scope": "punctuation.section.brackets.ttr",
          "match": "\\b(\\[|\\])\\b"
        }
      ]
    },
    "punctuation_section_parens_ttr": {
      "patterns": [
        {
          "scope": "punctuation.section.parens.ttr",
          "match": "\\b(\\(|\\))\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.separator.ttr",
          "match": "="
        },
        {
          "name": "punctuation.separator.ttr",
          "match": ":"
        },
        {
          "name": "punctuation.separator.ttr",
          "match": ","
        },
        {
          "name": "punctuation.separator.ttr",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.ttr",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.ttr",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.ttr",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.ttr",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.ttr",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.ttr",
          "match": "\\)"
        }
      ]
    }
  }
}