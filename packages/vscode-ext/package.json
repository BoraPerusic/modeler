{
  "name": "@modeler/vscode-ext",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "displayName": "TTR Modeler",
  "description": "Language support for TTR (Tatrman) modeling language",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:smoke": "pnpm run build && node ./dist/test/runTests.js",
    "build-generator": "tsc scripts/generate-tm-grammar.ts --outDir scripts --module nodenext --target es2022 --moduleResolution nodenext",
    "regen-tmgrammar": "pnpm run build-generator && node scripts/generate-tm-grammar.js"
  },
  "dependencies": {
    "@modeler/lsp": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "contributes": {
    "languages": [
      {
        "id": "ttr",
        "extensions": [
          ".ttr"
        ],
        "aliases": [
          "TTR"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ttr.svg",
          "dark": "./icons/ttr.svg"
        }
      },
      {
        "id": "ttrl",
        "extensions": [
          ".ttrl"
        ],
        "aliases": [
          "TTR Layout"
        ],
        "mimetypes": [
          "application/ttrl+json"
        ],
        "configuration": "./language-configuration-ttrl.json",
        "icon": {
          "light": "./icons/ttrl.svg",
          "dark": "./icons/ttrl.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ttr",
        "scopeName": "source.ttr",
        "path": "./syntaxes/ttr.tmLanguage.json"
      },
      {
        "language": "ttrl",
        "scopeName": "source.ttrl",
        "path": "./syntaxes/ttrl.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.ttrl",
        "url": "./schemas/ttrl.schema.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "TTR Language",
      "properties": {
        "ttr.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the TTR language server."
        }
      }
    },
    "commands": [
      {
        "command": "modeler.openInDesigner",
        "title": "Open in Designer",
        "description": "Opens the current TTR file in the graphical designer."
      }
    ]
  },
  "activationEvents": [
    "onLanguage:ttr"
  ]
}