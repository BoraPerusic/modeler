{
  "name": "@modeler/vscode-ext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "displayName": "TTR Modeler",
  "description": "Language support for TTR (Tatrman) modeling language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Formatters"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modeler/lsp": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "ttr",
        "extensions": [".ttr"],
        "aliases": ["TTR"]
      },
      {
        "id": "ttrl",
        "extensions": [".ttrl"],
        "aliases": ["TTR Layout"]
      }
    ],
    "grammars": [
      {
        "language": "ttr",
        "scopeName": "source.ttr",
        "path": "./syntaxes/ttr.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "TTR Language",
      "properties": {
        "ttr.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the TTR language server."
        }
      }
    },
    "commands": [
      {
        "command": "modeler.openInDesigner",
        "title": "Open in Designer",
        "description": "Opens the current TTR file in the graphical designer."
      }
    ]
  },
  "activationEvents": ["onLanguage:ttr"]
}